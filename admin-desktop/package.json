{
  "name": "rekberwe-admin-desktop",
  "version": "1.0.1",
  "description": "RekberWE Admin Dashboard for Windows",
  "private": true,
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:portable": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  },
  "build": {
    "appId": "id.rekberwe.admin",
    "productName": "RekberWE Admin",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "config.json",
      {
        "from": "../assets/rekberwe-favicon.png",
        "to": "assets/icon.png"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "RekberWE Admin"
    }
  }
}
