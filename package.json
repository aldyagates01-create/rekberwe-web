{
  "name": "rekberwe-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "npm install --prefix web && npm run build --prefix web",
    "start": "node --import tsx server/server.js",
    "dev": "node --import tsx --watch server/server.js",
    "dev:web": "npm run dev --prefix web",
    "check": "node --check app.js && node --check server/server.js"
  },
  "dependencies": {
    "better-sqlite3": "^11.10.0",
    "cloudinary": "^2.10.0",
    "dotenv": "^16.6.1",
    "express": "^4.21.2",
    "express-session": "^1.18.1",
    "jose": "^5.10.0",
    "multer": "^2.0.2",
    "next": "^15.1.7",
    "pg": "^8.22.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "resend": "^4.5.1",
    "tsx": "^4.19.3",
    "web-push": "^3.6.7"
  }
}
